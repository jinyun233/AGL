<!-- 主窗口页面 -->

<Window x:Class="Launcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="游戏启动器" Height="450" Width="600"
        WindowStartupLocation="CenterScreen">
    
    <Grid Margin="20">
        
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 标题 -->
        <TextBlock Grid.Row="0" Text="AGL启动器" 
                   FontSize="28" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,20"/>
        
        <!-- 内容显示区域 - 绑定到 ViewModel 的 ContentText -->
        <Border Grid.Row="1" BorderBrush="#CCC" BorderThickness="1" 
                CornerRadius="5" Padding="15" Background="#F5F5F5">
            <ScrollViewer>
                <TextBlock Text="占位！" 
                          FontSize="16" 
                          TextWrapping="Wrap"
                          VerticalAlignment="Center"/>
            </ScrollViewer>
        </Border>
        
        <!-- 按钮区域 - 绑定到 ViewModel 的命令 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" 
                    HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button 
                    Content="🚀 启动游戏" 
                    Width="120" Height="40" Margin="0,0,10,0"/>
            
            <Button 
                    Content="⚙️ 设置" 
                    Width="100" Height="40" Margin="0,0,10,0"/>
            
            <Button
                    Content="ℹ️ 关于" 
                    Width="100" Height="40"/>
        </StackPanel>
        
        <!-- 进度条 - 绑定到 IsStarting，自动显示/隐藏 -->
        <!-- <ProgressBar x:Name="ProgressBar" 
                    Grid.Row="1" 
                    Height="20" 
                    VerticalAlignment="Bottom" 
                    Visibility="{Binding IsStarting, 
                               Converter={StaticResource BoolToVisibilityConverter}}"
                    IsIndeterminate="True"
                    Margin="15"/> -->
    </Grid>
</Window>